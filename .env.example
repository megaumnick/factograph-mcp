# ─── Ollama (Windows PC) ──────────────────────────────────────────────────────
# IP Windows-машины в локальной сети. Узнать: ipconfig → IPv4
OLLAMA_HOST=http://192.168.1.XXX:11434
OLLAMA_MODEL=qwen3:14b

# Таймаут одного вызова Ollama, в мс. По умолчанию 600000 (10 минут).
# Подними, если видишь "500 | 1m59s" в логе llama.cpp и обрыв точно на границе
# текущего значения — это сигнал, что таймаут истёк раньше, чем модель закончила
# генерацию, а не что модель зависла.
#
# На 8GB VRAM сам Qwen3:14b в Q4_K_M (~8.9GB весов) физически не влезает
# в карту целиком — часть слоёв уходит на CPU, отсюда просадка до 4-5 ток/сек.
# Дешёвый фикс без смены модели — снизить num_ctx (см. ниже про detectConnections
# в enricher.ts) или перейти на более агрессивную квантизацию (qwen3:14b-q4_K_S)
# или меньшую модель (qwen3:8b) — обе варианта реально влезают в 8GB с запасом.
OLLAMA_TIMEOUT_MS=600000

# ─── Anthropic (fallback, опционально) ────────────────────────────────────────
# Используется если OLLAMA_HOST не задан
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Хранилище графа на диске (AUTO-SAVE) ─────────────────────────────────────
# При старте MCP загружает граф из этого файла.
# При SIGINT (остановке) — сохраняет обратно.
# Оставь пустым чтобы отключить.
AUTO_SAVE_PATH=/home/user/.document-pinboard/graph.json

# ─── Путь к SQLite (по умолчанию ~/.document-pinboard/pins.db) ────────────────
# DB_PATH=/home/user/.document-pinboard/pins.db

# ─── Безопасность файлового доступа ──────────────────────────────────────────
# Список директорий через ':', из которых MCP может читать файлы.
# Если пусто — доступ ко всей файловой системе (не рекомендуется).
ALLOWED_ROOTS=/home/user/documents:/mnt/data:/srv/knowledge
